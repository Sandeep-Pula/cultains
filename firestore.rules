rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isSignedIn() &&
        request.auth.token.email != null &&
        request.auth.token.email == 'superadmin@aivyapari.com';
    }

    function isWorkspaceMember(userId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'team_member' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.workspaceOwnerId == userId;
    }

    function managesTeamAccount(userId) {
      return isSignedIn() && (
        (request.resource != null && request.resource.data.workspaceOwnerId == request.auth.uid) ||
        (resource != null && resource.data.workspaceOwnerId == request.auth.uid)
      );
    }

    match /users/{userId} {
      allow read: if isSuperAdmin() || isOwner(userId) || isWorkspaceMember(userId) || managesTeamAccount(userId);
      allow write: if isSuperAdmin() || isOwner(userId) || managesTeamAccount(userId);

      match /{document=**} {
        allow read, write: if isSuperAdmin() || isOwner(userId) || isWorkspaceMember(userId);
      }
    }

    match /supportThreads/{ticketId} {
      allow read: if isSuperAdmin() || (
        resource.data.ownerUserId != null &&
        (isOwner(resource.data.ownerUserId) || isWorkspaceMember(resource.data.ownerUserId))
      );

      allow create: if isSuperAdmin() || (
        request.resource.data.ownerUserId != null &&
        (isOwner(request.resource.data.ownerUserId) || isWorkspaceMember(request.resource.data.ownerUserId))
      );

      allow update: if isSuperAdmin() || (
        resource.data.ownerUserId != null &&
        (isOwner(resource.data.ownerUserId) || isWorkspaceMember(resource.data.ownerUserId))
      );

      allow delete: if isSuperAdmin();
    }
  }
}
